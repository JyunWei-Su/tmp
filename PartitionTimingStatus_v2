def _parse_sta_directory(base_dir: str, partition_name: str,
                         threshold: float) -> tuple:
    """
    Parse one STA output directory and collect all timing metrics.
    Returns (row, pba_sections, scenario_mode).
      row          : flat dict keyed by column name constants.
      pba_sections : raw dict from parse_pba_violations (empty if not found).
      scenario_mode: 'DMSA', 'single', or 'NA'.
    """
    # --- defaults ---
    row = {
        COL_PARTITION:        partition_name,
        COL_APR_STAGE:        "NA",
        COL_SI_NSI:           "NA",
        COL_SI_PARAMS_ERRORS: "NA",
        COL_FILE_ADDR:        "",
        COL_COMMENT:          "",
    }
    for cat in PATH_CATEGORIES:
        row[col_setup(cat)] = "NA"
        row[col_hold(cat)]  = "NA"
    row[col_max_trans_vio(threshold)] = "NA"
    row[COL_MAX_CAP_VIO]              = "NA"
    row[COL_MIN_PULSE_WIDTH]          = "NA"
    row[COL_MIN_PERIOD]               = "NA"
    row[COL_NOISE]                    = "NA"
    row[COL_DOUBLE_SWITCHING]         = "NA"

    if not os.path.exists(base_dir):
        logging.error(f"STA directory not found: {base_dir}")
        return row, {}, "NA"

    logging.info(f"Parsing partition '{partition_name}': {base_dir}")
    row[COL_FILE_ADDR] = os.path.realpath(base_dir)
    scenario_mode, design_stage, si_enable, _ = parse_pt_log(base_dir)
    row[COL_APR_STAGE] = design_stage
    # Normalise SI_ENABLE: strip whitespace, case-insensitive → "SI" / "nSI" / "NA"
    _si = si_enable.strip().lower() if isinstance(si_enable, str) else ""
    if _si == "true":
        row[COL_SI_NSI] = "SI"
    elif _si == "false":
        row[COL_SI_NSI] = "nSI"
    else:
        row[COL_SI_NSI] = "NA"

    reports_dir = Path(base_dir) / 'reports'
    if not reports_dir.exists():
        logging.error(f"reports/ subdirectory not found in: {base_dir}")
        return row, {}, scenario_mode

    full_reports_path = str(reports_dir.resolve())

    # ── Setup / Hold ──────────────────────────────────────────
    timing_files = sorted(
        p for p in reports_dir.glob('*global_timing.report*')
        if p.name.endswith('.report') or p.name.endswith('.report.gz')
    )
    if timing_files:
        data = _read_file(str(timing_files[-1]))
        vio  = parse_violations(data)
        setup_hdrs, setup_vals = _format_violations(vio["Setup"], "Setup")
        hold_hdrs,  hold_vals  = _format_violations(vio["Hold"],  "Hold")
        for h, v in zip(setup_hdrs, setup_vals):
            row[h] = v
        for h, v in zip(hold_hdrs, hold_vals):
            row[h] = v
    else:
        logging.error(f"No global_timing.report found in {full_reports_path}")

    # ── PBA violations ────────────────────────────────────────
    sections = {}
    pba_files = sorted(
        p for p in reports_dir.glob('*PBA_violate.report*')
        if p.name.endswith('.report') or p.name.endswith('.report.gz')
    )
    if pba_files:
        data = _read_file(str(pba_files[-1]))
        sections, err = parse_pba_violations(data, threshold, scenario_mode)
        if err:
            logging.error(f"Errors detected in PBA report: {pba_files[-1]}")
        _, _, mt_num, mt_lt = _sum_pba_section(sections, 'max_transition')
        _, _, mc_num, _     = _sum_pba_section(sections, 'max_capacitance')
        _, _, mp_num, _     = _sum_pba_section(sections, 'min_period')
        _, _, mpw_num, _    = _sum_pba_section(sections, 'min_pulse_width')
        row[col_max_trans_vio(threshold)] = f"{mt_lt}/{mt_num}" if data != "NA" else "NA"
        row[COL_MAX_CAP_VIO]              = str(mc_num)  if data != "NA" else "NA"
        row[COL_MIN_PERIOD]               = str(mp_num)  if data != "NA" else "NA"
        row[COL_MIN_PULSE_WIDTH]          = str(mpw_num) if data != "NA" else "NA"
    else:
        logging.error(f"No PBA_violate.report found in {full_reports_path}")

    # ── SI noise ──────────────────────────────────────────────
    noise_files = sorted(
        p for p in reports_dir.glob('*report_noise_all_violate.report*')
        if p.name.endswith('.report') or p.name.endswith('.report.gz')
    )
    if noise_files and si_enable == "true":  # si_enable still holds raw value here
        data = _read_file(str(noise_files[-1]))
        row[COL_NOISE] = parse_si_noise(data)

        # SI double switching (per-scenario sub-directories)
        total_ds = 0
        for sub in reports_dir.iterdir():
            if not sub.is_dir():
                continue
            for ds_file in sub.glob('*report_si_double_switching.report*'):
                v = parse_si_double_switching(_read_file(str(ds_file)))
                if v == "NA":
                    total_ds = "NA"
                    break
                total_ds += v
            if total_ds == "NA":
                break
        row[COL_DOUBLE_SWITCHING] = total_ds
    else:
        logging.warning(f"SI noise reports not found or SI disabled in {full_reports_path}")

    # ── SI params errors (post-route only) ────────────────────
    if design_stage == "post-route":
        work_dir = Path(base_dir) / 'work'
        if scenario_mode == "single":
            sub_dirs = [str(base_dir)]
        elif work_dir.exists():
            sub_dirs = [str(work_dir / d)
                        for d in os.listdir(work_dir)
                        if (work_dir / d).is_dir()]
        else:
            sub_dirs = []
        total_err = 0
        for sub in sub_dirs:
            for pf in glob.glob(os.path.join(sub, '*parasitics_command.log*')):
                v = parse_si_params(_read_file(pf))
                if v == "NA":
                    total_err = "NA"
                    break
                total_err += v
            if total_err == "NA":
                break
        row[COL_SI_PARAMS_ERRORS] = total_err

    na_fields = [k for k, v in row.items() if v == "NA"]
    if na_fields:
        logging.warning(f"  [{partition_name}] NA fields: {', '.join(na_fields)}")
    else:
        logging.info(f"  [{partition_name}] OK — all fields parsed")
    return row, sections, scenario_mode


def mode_extract(config_file: str, threshold: float, output_ods: bool):
    """
    Extract mode: read config (xlsx/ods), parse each STA directory,
    write Partition_Timing_Status_<timestamp>.xlsx (or .ods).
    """
    # FIX: specify sheet_name=0 to always get a DataFrame, not a dict
    cfg_df = read_xlsx_ods(config_file, sheet_name=0)
    cfg_df.columns = [c.strip() for c in cfg_df.columns]

    rows              = []
    partition_details = []   # [(partition_name, sections, scenario_mode), ...]
    total = sum(
        1 for _, r in cfg_df.iterrows()
        if str(r.get(CFG_COL_PARTITION, "")).strip()
    )
    # Columns to check for NA (exclude free-text / path fields and optional metrics)
    _na_check_exclude = {COL_FILE_ADDR, COL_COMMENT, COL_BEOWNER,
                         COL_NOISE, COL_DOUBLE_SWITCHING}

    with Progress(
        TextColumn("[progress.description]{task.description}"),
        BarColumn(),
        MofNCompleteColumn(),
        console=_console,
        transient=False,
    ) as progress:
        task = progress.add_task("Parsing", total=total)
        for _, cfg_row in cfg_df.iterrows():
            partition = str(cfg_row.get(CFG_COL_PARTITION, "")).strip()
            beowner   = str(cfg_row.get(CFG_COL_BEOWNER,   "")).strip()
            sta_dir   = str(cfg_row.get(CFG_COL_STA_DIR,   "")).strip()
            if not partition:
                continue
            metrics, sections, scenario_mode = _parse_sta_directory(sta_dir, partition, threshold)
            metrics[COL_BEOWNER] = beowner
            rows.append(metrics)
            partition_details.append((partition, sections, scenario_mode))
            progress.advance(task)

            na_fields = [
                k for k, v in metrics.items()
                if v == "NA" and k not in _na_check_exclude
            ]
            if na_fields:
                _console.print(
                    f"  [red]✗[/red] {partition} — NA: {', '.join(na_fields)}"
                )
            else:
                _console.print(f"  [green]✓[/green] {partition}")

    if not rows:
        print(f"{COLOR_R}Error: No valid partitions found in config.{NO_COLOR}")
        sys.exit(1)

    df = pd.DataFrame(rows).set_index(COL_PARTITION)

    # Enforce column order
    fixed   = [COL_BEOWNER, COL_APR_STAGE, COL_SI_NSI, COL_COMMENT, COL_SI_PARAMS_ERRORS]
    setup   = [col_setup(c) for c in PATH_CATEGORIES]
    hold    = [col_hold(c)  for c in PATH_CATEGORIES]
    other   = [col_max_trans_vio(threshold), COL_MAX_CAP_VIO,
               COL_MIN_PULSE_WIDTH, COL_MIN_PERIOD,
               COL_NOISE, COL_DOUBLE_SWITCHING, COL_FILE_ADDR]
    ordered = [c for c in (fixed + setup + hold + other) if c in df.columns]
    extra   = [c for c in df.columns if c not in ordered]
    df      = df[ordered + extra]

    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    out_xlsx  = f"Partition_Timing_Status_{timestamp}.xlsx"

    with pd.ExcelWriter(out_xlsx, engine='openpyxl') as writer:
        _write_sheet(writer, df,
                     sheet_name    = 'Overall',
                     freeze        = 'E2',
                     color_rules   = EXTRACT_COLOR_RULES,
                     hide_patterns = EXTRACT_HIDE_DEFAULT)
        for pname, sections, scenario_mode in partition_details:
            _write_partition_sheets(writer, pname, sections, scenario_mode)

    # Remove stale symlinks
    for ext in ('xlsx', 'ods'):
        link = f"Partition_Timing_Status_current.{ext}"
        if os.path.exists(link) or os.path.islink(link):
            os.remove(link)

    if output_ods:
        ods_path = convert_to_ods_shared(out_xlsx, freeze='E2', sheet_name='Overall')
        os.symlink(ods_path, "Partition_Timing_Status_current.ods")
    else:
        print(f"Output written to: {out_xlsx}")
        os.symlink(out_xlsx, "Partition_Timing_Status_current.xlsx")


