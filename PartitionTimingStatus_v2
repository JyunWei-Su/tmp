def _strip_col_spaces(df: pd.DataFrame) -> pd.DataFrame:
    """Remove spaces from all string column names."""
    return df.rename(columns={
        c: c.strip().replace(' ', '') if isinstance(c, str) else c
        for c in df.columns
    })


def _strip_list_spaces(lst: list) -> list:
    return [s.replace(' ', '') for s in lst]


def tag_columns_with_date(df: pd.DataFrame, date: str,
                          exclude: list = []) -> pd.DataFrame:
    """
    Append _v{mmdd} suffix to columns not already versioned (pattern _v####),
    not already a diff column (ending in _diff), and not in exclude list.
    """
    df      = _strip_col_spaces(df)
    exclude = _strip_list_spaces(exclude)
    mmdd    = date[4:]
    pat_ver  = re.compile(r'_v\d{4}$')
    pat_diff = re.compile(r'_diff$')
    new_cols = {}
    for col in df.columns:
        if not isinstance(col, str):
            new_cols[col] = col
        elif any(fnmatch.fnmatch(col, p) for p in exclude):
            new_cols[col] = col
        elif pat_ver.search(col) or pat_diff.search(col):
            new_cols[col] = col   # already versioned or already a diff → leave as-is
        else:
            new_cols[col] = f"{col}_v{mmdd}"
    return df.rename(columns=new_cols)


def select_columns(df: pd.DataFrame,
                   include: list = [], exclude: list = []) -> pd.DataFrame:
    """
    Filter columns by fnmatch include/exclude patterns.
    Sets Partition as index, drops duplicate partitions and empty rows.
    """
    df = _strip_col_spaces(df)
    if df.index.name != COL_PARTITION:
        df = df.set_index(COL_PARTITION, drop=True)
    df  = df[~df.index.duplicated(keep='first')]
    inc = _strip_list_spaces(df.columns.tolist() if not include else include)
    exc = _strip_list_spaces(exclude)
    cols = [c for c in df.columns if     any(fnmatch.fnmatch(c, p) for p in inc)]
    cols = [c for c in cols       if not any(fnmatch.fnmatch(c, p) for p in exc)]
    df   = df[cols].copy()
    df   = df[~df.index.isna()]
    df   = df[~(df.index.astype(str).str.strip() == '')]
    return df


def lookup_partitions(df: pd.DataFrame, partitions: list,
                      cols: list = []) -> pd.DataFrame:
    """Reindex df to exact partitions list; return specified cols (or all)."""
    df = _strip_col_spaces(df)
    if df.index.name != COL_PARTITION:
        df = df.set_index(COL_PARTITION, drop=True)
    df       = df[~df.index.duplicated(keep='first')]
    col_list = _strip_list_spaces(df.columns.tolist() if not cols else cols)
    return df.reindex(partitions)[col_list]


def merge_dataframes(df_list: list, sort_list: list = [],
                     date_new: str = None, date_old: str = None) -> pd.DataFrame:
    """
    Outer-join a list of DataFrames on their index.
    If sort_list is given, reorder columns: for each base name in sort_list,
    group columns as [_diff, _v{new}, _v{old}, _v{older}..., exact] so that
    all versioned variants of the same item stay together.
    """
    if not df_list:
        return pd.DataFrame()
    merged = pd.concat(
        [df if isinstance(df, pd.DataFrame) else pd.DataFrame(df)
         for df in df_list],
        axis=1, join='outer'
    )
    if sort_list and date_new and date_old:
        ordered, used = [], set()
        sfx_new = date_new[4:]
        sfx_old = date_old[4:]
        _pat_ver = re.compile(r'_v(\d{4})$')
        for pat in sort_list:
            # 1. _diff column
            # 2. _v{new} column
            # 3. _v{old} column
            # 4. any remaining _v{mmdd} columns for this base, sorted newest→oldest
            # 5. exact unversioned (metadata)
            for suffix in [f'_diff', f'_v{sfx_new}', f'_v{sfx_old}']:
                candidates = [c for c in merged.columns
                              if c not in used and str(c) == f"{pat}{suffix}"]
                ordered.extend(candidates)
                used.update(candidates)
            # collect any other _v{mmdd} columns for this base (from older diff inputs)
            extra_ver = [
                c for c in merged.columns
                if c not in used and _pat_ver.search(str(c))
                and str(c).startswith(pat + '_v')
            ]
            extra_ver.sort(key=lambda c: _pat_ver.search(c).group(1), reverse=True)
            ordered.extend(extra_ver)
            used.update(extra_ver)
            # exact unversioned match (metadata columns)
            exact = [c for c in merged.columns if c not in used and str(c) == pat]
            ordered.extend(exact)
            used.update(exact)
        remaining = sorted([c for c in merged.columns if c not in used], reverse=True)
        merged = merged[ordered + remaining]
    return merged


def compute_diff(df: pd.DataFrame, date_new: str, date_old: str,
                 cols: list) -> pd.DataFrame:
    """
    For each base column name in cols, add a {col}_diff column = new - old.
    Values may be scalar or 'a / b / c' slash-separated multi-values.
    """
    sfx_new = f"_v{date_new[4:]}"
    sfx_old = f"_v{date_old[4:]}"

    def _parse(val):
        if pd.isna(val):
            return None
        if isinstance(val, (int, float)):
            return float(val)
        parts = [p.strip() for p in str(val).split('/') if p.strip()]
        try:
            return [float(p) for p in parts]
        except ValueError:
            return None

    def _diff_row(row, cn, co):
        n, o = _parse(row[cn]), _parse(row[co])
        if n is None or o is None:
            return pd.NA
        if isinstance(n, float) and isinstance(o, float):
            d = n - o
            return int(d) if d == int(d) else d
        if isinstance(n, list) and isinstance(o, list) and len(n) == len(o):
            diffs = [ni - oi for ni, oi in zip(n, o)]
            return " / ".join(
                f"{int(d)}" if d == int(d) else f"{d:.4f}" for d in diffs
            )
        return pd.NA

    for col in _strip_list_spaces(cols):
        cn = f"{col}{sfx_new}"
        co = f"{col}{sfx_old}"
        if cn in df.columns and co in df.columns:
            df[f"{col}_diff"] = df.apply(lambda r, cn=cn, co=co: _diff_row(r, cn, co), axis=1)
    return df


def get_date_from_filename(filename: str) -> str:
    """Extract yyyymmdd from filename. Returns '00000000' if not found."""
    m = re.search(r'(\d{8})', os.path.basename(filename))
    return m.group(1) if m else '00000000'


def _normalize_legacy_columns(df: pd.DataFrame) -> pd.DataFrame:
    """
    Detect and rename legacy column names (Partition_Timing_Status v1 /
    diff_partition_timing_status) to v2 CamelCase convention.

    Handles both plain columns (from extract files) and versioned columns
    (from diff files, e.g. 'doubleswitching_v0101' → 'DoubleSwitching_v0101').

    Old base name (after space-strip) → New v2 base name
      APRstage                       → APRStage
      Max_transvio.(lessthanX/total) → MaxTransVio(lt{X}/Total)  (sign preserved)
      Max_capvio.                    → MaxCapVio
      min_pulse_width                → MinPulseWidth
      min_period                     → MinPeriod
      noise                          → Noise
      doubleswitching                → DoubleSwitching
    """
    df = _strip_col_spaces(df)   # normalise spaces first

    _pat_max_trans = re.compile(
        r'^Max_transvio\.\(lessthan(-?[\d.]+)/total\)$', re.IGNORECASE
    )
    _pat_ver_suffix = re.compile(r'^(.+?)(_v\d{4})$')

    _STATIC: dict = {
        'APRstage':        COL_APR_STAGE,
        'Max_capvio.':     COL_MAX_CAP_VIO,
        'min_pulse_width': COL_MIN_PULSE_WIDTH,
        'min_period':      COL_MIN_PERIOD,
        'noise':           COL_NOISE,
        'doubleswitching': COL_DOUBLE_SWITCHING,
    }

    def _norm_base(base: str) -> str:
        m = _pat_max_trans.match(base)
        if m:
            try:
                val = float(m.group(1))   # preserve sign to match v2 col name
                return f"MaxTransVio(lt{val:g}/Total)"
            except ValueError:
                pass
        return _STATIC.get(base, base)

    rename_map: dict = {}
    for col in df.columns:
        if not isinstance(col, str):
            continue
        vm = _pat_ver_suffix.match(col)
        if vm:
            base, ver = vm.group(1), vm.group(2)
            new_base = _norm_base(base)
            if new_base != base:
                rename_map[col] = f"{new_base}{ver}"
        else:
            new_name = _norm_base(col)
            if new_name != col:
                rename_map[col] = new_name

    if rename_map:
        _console.print(
            f"  [yellow]⚑[/yellow] Legacy columns normalised: "
            + ", ".join(f"{k} → {v}" for k, v in rename_map.items())
        )
        df = df.rename(columns=rename_map)
    return df


