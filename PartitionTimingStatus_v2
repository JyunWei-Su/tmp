if __name__ == '__main__':
    logging.basicConfig(
        filename='partition_timing_status.log',
        filemode='w', level=logging.DEBUG,
        format='%(asctime)s [%(levelname)s] %(message)s',
        datefmt='%Y-%m-%d %H:%M:%S',
    )

    parser = argparse.ArgumentParser(
        description='Partition Timing Status — extract STA results, diff two reports, '
                    'or generate a config template.',
        formatter_class=argparse.RawTextHelpFormatter,
    )

    mode_group = parser.add_mutually_exclusive_group(required=True)
    mode_group.add_argument(
        '--from', dest='config', metavar='CONFIG',
        help='Extract mode: path to config.ods / config.xlsx'
    )
    mode_group.add_argument(
        '--diff', action='store_true',
        help='Diff mode: compare two Partition_Timing_Status files\n'
             '  requires --old and --new'
    )
    mode_group.add_argument(
        '--example', action='store_true',
        help='Generate a sample config.ods template and exit'
    )

    parser.add_argument('--old', metavar='FILE',
                        help='Older timing status file (diff mode)')
    parser.add_argument('--new', metavar='FILE',
                        help='Newer timing status file (diff mode)')
    parser.add_argument(
        '--max-trans', dest='max_trans', type=float, default=-0.1,
        metavar='VALUE',
        help='Max-trans slack threshold for violation count (default: -0.1)'
    )
    parser.add_argument(
        '--output-ods', dest='output_ods', action='store_true',
        help='Convert output to ODS format with shared edit mode enabled'
    )

    args = parser.parse_args()

    # ── Validate diff mode ─────────────────────────────────────
    if args.diff:
        if not args.old or not args.new:
            parser.error("--diff requires both --old and --new")
        name_pattern = r'^Partition_Timing_Status_\d{8}.*\.(ods|xlsx)$'
        for flag, path in [('--old', args.old), ('--new', args.new)]:
            if not re.match(name_pattern, os.path.basename(path)):
                print(f"{COLOR_R}Error: {flag} filename must match "
                      f"Partition_Timing_Status_<yyyymmdd>*.(xlsx|ods){NO_COLOR}")
                sys.exit(1)
            if not os.path.isfile(path):
                print(f"{COLOR_R}Error: {flag} file not found: {path}{NO_COLOR}")
                sys.exit(1)
        if get_date_from_filename(args.old) == get_date_from_filename(args.new):
            print(f"{COLOR_R}Error: --old and --new files share the same date{NO_COLOR}")
            sys.exit(1)

    # ── LibreOffice conflict check (only when soffice will be invoked) ──
    needs_soffice = (
        args.output_ods
        or args.example
        or (args.config and os.path.splitext(args.config)[1].lower() == '.ods')
        or (args.diff and (
            (args.old and os.path.splitext(args.old)[1].lower() == '.ods') or
            (args.new and os.path.splitext(args.new)[1].lower() == '.ods')
        ))
    )
    if needs_soffice:
        check_libreoffice_conflict()

    # ── Dispatch ───────────────────────────────────────────────
    try:
        if args.example:
            mode_example()
        elif args.diff:
            mode_diff(args.old, args.new, args.output_ods)
        else:
            mode_extract(args.config, args.max_trans, args.output_ods)
    except KeyboardInterrupt:
        print(f"\n{COLOR_Y}Interrupted by user.{NO_COLOR}")
        sys.exit(130)  # Unix convention: 128 + SIGINT