def _apply_header_style(ws):
    """Yellow background + bold + left-align + vertical-center for header row."""
    for cell in ws[1]:
        cell.fill      = FILL_HEADER
        cell.font      = Font(bold=True)
        cell.alignment = Alignment(horizontal='left', vertical='center')


def _apply_row_colors(ws):
    """Alternating light-red / light-blue for data rows (row 2+), vertical-center."""
    for i, row in enumerate(ws.iter_rows(min_row=2, max_row=ws.max_row)):
        fill = FILL_ROW_EVEN if i % 2 == 0 else FILL_ROW_ODD
        for cell in row:
            cell.fill      = fill
            cell.alignment = Alignment(horizontal='left', vertical='center')


def _apply_diff_col_colors(ws):
    """Dark red/blue for data cells in columns whose header contains '_diff'."""
    for col in ws.iter_cols(min_row=1, max_row=ws.max_row):
        hdr = col[0].value
        if isinstance(hdr, str) and '_diff' in hdr.lower():
            for i, cell in enumerate(col[1:]):
                cell.fill = FILL_DIFF_EVEN if i % 2 == 0 else FILL_DIFF_ODD


def apply_cell_color_rules(ws, df_out: pd.DataFrame,
                           rules: List[CellColorRule]):
    """
    Apply pluggable CellColorRule list to worksheet.
    df_out must be the already-reset-index DataFrame (matching Excel column order).
    """
    col_indices = {str(col): idx + 1 for idx, col in enumerate(df_out.columns)}

    for rule in rules:
        matched = [c for c in col_indices if fnmatch.fnmatch(str(c), rule.col_pattern)]
        for col_name in matched:
            col_idx = col_indices[col_name]
            for row_idx in range(2, ws.max_row + 1):
                cell = ws.cell(row=row_idx, column=col_idx)
                try:
                    if rule.condition(cell.value):
                        if rule.font_color:
                            cell.font = Font(color=rule.font_color)
                        if rule.fill_color:
                            cell.fill = PatternFill(fill_type="solid",
                                                    fgColor=rule.fill_color)
                        # preserve vertical-center set by _apply_row_colors
                        cell.alignment = Alignment(
                            horizontal=cell.alignment.horizontal or 'left',
                            vertical='center',
                            wrap_text=cell.alignment.wrap_text,
                        )
                except Exception:
                    pass  # Skip cells where condition raises (e.g. string vs numeric)


def _apply_hidden_columns(ws, hide_patterns: list):
    """Hide columns matching any fnmatch pattern. Data is preserved."""
    for col in ws.iter_cols(min_row=1, max_row=1):
        hdr = col[0].value
        if isinstance(hdr, str) and any(fnmatch.fnmatch(hdr, p) for p in hide_patterns):
            ws.column_dimensions[col[0].column_letter].hidden = True


def _auto_col_width(ws, max_width: int = 35):
    """Set column width to content length + padding, capped at max_width."""
    for col in ws.columns:
        letter  = col[0].column_letter
        max_len = max(
            (len(str(c.value)) for c in col if c.value is not None),
            default=0
        )
        ws.column_dimensions[letter].width = min(max_len + 4, max_width)


def _apply_comment_wrap(ws):
    """
    Enable wrap_text for Comment columns and auto-adjust row height based on
    the longest Comment value in each row (15pt per line, min 15pt).
    openpyxl does not compute row height automatically after wrap_text is set,
    so we estimate it here.
    """
    # Collect (col_index, col_width) for all Comment columns
    comment_cols: List[tuple] = []
    for col in ws.iter_cols(min_row=1, max_row=1):
        hdr = col[0].value
        if isinstance(hdr, str) and hdr.startswith('Comment'):
            col_letter = col[0].column_letter
            col_width  = ws.column_dimensions[col_letter].width or 10
            comment_cols.append((col[0].column, col_width))

    if not comment_cols:
        return

    CHAR_PER_LINE = 1.2   # approximate chars per unit of column width
    LINE_HEIGHT   = 15.0  # points per line
    MIN_HEIGHT    = 15.0

    for row_idx in range(2, ws.max_row + 1):
        max_lines = 1
        for col_idx, col_width in comment_cols:
            cell = ws.cell(row=row_idx, column=col_idx)
            cell.alignment = Alignment(
                horizontal='left', vertical='center', wrap_text=True
            )
            val = str(cell.value) if cell.value is not None else ""
            if not val:
                continue
            chars_per_line = max(1, int(col_width * CHAR_PER_LINE))
            # Count explicit newlines too
            lines = 0
            for segment in val.split('\n'):
                lines += max(1, -(-len(segment) // chars_per_line))  # ceiling div
            max_lines = max(max_lines, lines)

        ws.row_dimensions[row_idx].height = max(MIN_HEIGHT, max_lines * LINE_HEIGHT)


def _write_sheet(writer, df: pd.DataFrame, sheet_name: str,
                 freeze: str,
                 color_rules: List[CellColorRule],
                 hide_patterns: List[str]):
    """
    Write df to a new sheet with full styling applied in order:
      row colors → diff-col colors → header (overrides row 1) →
      cell rules → timing diff colors → comment wrap →
      hidden cols → col widths → freeze panes
    """
    df_out = df.reset_index()
    df_out.to_excel(writer, sheet_name=sheet_name, index=False)
    ws = writer.book[sheet_name]
    _apply_row_colors(ws)
    _apply_diff_col_colors(ws)
    _apply_header_style(ws)          # applied last so header always wins row 1
    apply_cell_color_rules(ws, df_out, color_rules)
    _apply_timing_diff_colors(ws, df_out)
    _apply_hidden_columns(ws, hide_patterns)
    _auto_col_width(ws)              # must run before _apply_comment_wrap (needs col widths)
    _apply_comment_wrap(ws)          # wrap + row-height estimation uses col widths
    ws.freeze_panes = freeze


