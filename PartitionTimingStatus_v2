def _read_file(file_path: str) -> str:
    """Read plain-text or gzip file; return content string or 'NA' on failure."""
    try:
        with open(file_path, 'rb') as f:
            is_gz = f.read(2) == b'\x1f\x8b'
        if is_gz:
            with gzip.open(file_path, 'rt', encoding='utf-8') as f:
                return f.read()
        else:
            with open(file_path, 'r', encoding='utf-8') as f:
                return f.read()
    except Exception:
        return "NA"


def parse_pt_log(directory: str):
    """
    Parse pt.log for run configuration.
    Returns (scenario_mode, design_stage, si_enable, design_name).
    All values default to 'NA' if not found.
    """
    pt_log = os.path.join(directory, 'pt.log')
    if not os.path.exists(pt_log):
        logging.warning(f"pt.log not found: {pt_log}")
        return "NA", "NA", "NA", "NA"

    scenario_mode = design_stage = si_enable = design_name = "NA"
    in_setup = False

    with open(pt_log, 'r', encoding='latin-1') as f:
        for line in f:
            if "SETUP_PT.tcl.user" in line or "## My Setting  ##" in line:
                in_setup = True
                continue
            if not in_setup or line.startswith('#'):
                continue
            if re.search(r'set\s+SCENARIO_MODE', line):
                parts = line.split('"')
                if len(parts) > 1:
                    scenario_mode = parts[1]
            elif re.search(r'set\s+DESIGN_STAGE', line):
                parts = line.split('"')
                if len(parts) > 1:
                    design_stage = parts[1]
            elif re.search(r'set\s+SI_ENABLE', line):
                parts = line.split('"')
                if len(parts) > 1:
                    si_enable = parts[1]
            elif re.search(r'set\s+DESIGN_NAME', line):
                in_setup = False
                parts = line.split('"')
                if len(parts) > 1:
                    design_name = parts[1]

    return scenario_mode, design_stage, si_enable, design_name


def parse_violations(data: str) -> dict:
    """
    Parse *global_timing.report* for Setup/Hold WNS/TNS/NUM.

    Returns:
        {
          "Setup": [[wns×5], [tns×5], [num×5]],
          "Hold":  [[wns×5], [tns×5], [num×5]]
        }
    where index 0-4 correspond to PATH_CATEGORIES.
    """
    lines     = data.strip().split('\n')
    result    = {"Setup": [], "Hold": []}
    current   = None
    err_flag  = False

    for line in lines:
        if "Error" in line:
            err_flag = True
        line = line.strip()
        if "Setup violations" in line:
            current = "Setup"
        elif "Hold violations" in line:
            current = "Hold"
        elif current and (line.startswith("WNS") or
                          line.startswith("TNS") or
                          line.startswith("NUM")):
            result[current].append(line.split()[1:])

    placeholder = lambda: (
        ['err'] * 5 if err_flag else
        (['0']  * 5 if data != "NA" else ['NA'] * 5)
    )
    for key in result:
        while len(result[key]) < 3:
            result[key].append(placeholder())

    return result


def parse_pba_violations(data: str, threshold: float, scenario_mode: str) -> tuple:
    """
    Parse *PBA_violate.report* for max_transition / max_capacitance /
    min_period / min_pulse_width sections.

    Returns (sections_dict, err_flag) where sections_dict is:
        { violation_type: { clock_group: { scenario: {WNS, TNS, NUM, LessThan} } } }
    """
    lines            = data.strip().split('\n')
    err_flag         = False
    sections         = {}
    current_section  = 0
    delay_group      = 0
    prev_section     = 0
    prev_delay_group = 0
    scenarios_dict   = {}
    prev_lines       = []
    current_line     = ""
    max_min_pat      = r'(\w+_delay)/.*?\'(.+?)\'\s+group'

    for line in lines:
        if "Error" in line:
            err_flag = True
        line = line.strip()

        if len(prev_lines) == 6:
            prev_lines.pop(0)
        prev_lines.append(line)

        # Section separator: a stripped line with '-' at position 60
        if line.startswith('-', 60):
            match = None
            if scenario_mode == "DMSA" and len(prev_lines) > 1:
                match = re.search(max_min_pat, prev_lines[1])
            elif scenario_mode == "single" and len(prev_lines) > 0:
                match = re.search(max_min_pat, prev_lines[0])

            prev_section     = current_section
            prev_delay_group = delay_group

            if match:
                current_section = match.group(1)
                delay_group     = match.group(2)
            else:
                current_section = prev_lines[1] if len(prev_lines) > 1 else ""
                delay_group     = "NA"

            if current_section not in sections:
                sections[current_section] = {}
            if prev_section != 0 and prev_delay_group != 0:
                sections[prev_section][prev_delay_group] = scenarios_dict
            sections[current_section][delay_group] = {}
            scenarios_dict = {}
            current_line   = ""
            continue

        if line:
            current_line = (current_line + " " + line) if current_line else line

        if "VIOLATED" in line:
            parts      = current_line.split()
            is_pulse   = "pulse_width" in str(current_section)
            if scenario_mode == "DMSA":
                scenario  = parts[2] if is_pulse else parts[1]
                slack_idx = 5        if is_pulse else 4
            else:  # single
                scenario  = "NA"
                slack_idx = 4 if is_pulse else 3
            try:
                slack = float(parts[slack_idx])
            except (IndexError, ValueError):
                current_line = ""
                continue

            if scenario not in scenarios_dict:
                scenarios_dict[scenario] = {"WNS": slack, "TNS": 0.0, "NUM": 0, "LessThan": 0}
            s = scenarios_dict[scenario]
            s["TNS"]      += slack
            s["NUM"]      += 1
            s["WNS"]       = min(s["WNS"], slack)
            if slack < threshold:
                s["LessThan"] += 1
            current_line = ""

        if line == "1":
            sections[current_section][delay_group] = scenarios_dict

    return sections, err_flag


def parse_si_noise(data: str):
    """Count SI noise violations from *report_noise_all_violate.report*."""
    if data == "NA":
        return "NA"
    total      = 0
    in_section = False
    for line in data.strip().split('\n'):
        line = line.strip()
        if line.startswith("pin name"):
            in_section = True
        elif in_section and line and not any(line.startswith(p) for p in ("-", "1", "noise_region")):
            total += 1
    return total


def parse_si_double_switching(data: str):
    """Count SI double-switching violations from *report_si_double_switching.report*."""
    if data == "NA":
        return "NA"
    total      = 0
    in_section = False
    for line in data.strip().split('\n'):
        line = line.strip()
        if line.startswith("~~~~~~~~~~~~~"):
            in_section = True
        elif in_section and line and not line.startswith("1"):
            total += 1
    return total


def parse_si_params(data: str):
    """Parse SI params error count from *parasitics_command.log*."""
    if data == "NA":
        return "NA"
    for line in data.strip().split('\n'):
        if 'error(s)' in line:
            m = re.search(r'\d+', line)
            return int(m.group()) if m else "NA"
    return "NA"


def _format_violations(violations: list, prefix: str):
    """
    Format violations [[wns×5],[tns×5],[num×5]] into column headers and
    'wns/tns/num' value strings for each path category.
    """
    headers = [f"{prefix}({cat})" for cat in PATH_CATEGORIES]
    values  = [
        f"{violations[0][i]}/{violations[1][i]}/{violations[2][i]}"
        for i in range(len(PATH_CATEGORIES))
    ]
    if all(v == 'NA/NA/NA' for v in values):
        values = ['NA'] * len(PATH_CATEGORIES)
    return headers, values


def _sum_pba_section(sections: dict, key: str) -> tuple:
    """Aggregate WNS/TNS/NUM/LessThan across all groups and scenarios for one violation type."""
    total_wns = 0
    total_tns = 0.0
    total_num = 0
    total_lt  = 0
    if key in sections:
        for _, scenarios in sections[key].items():
            for _, s in scenarios.items():
                total_wns  = min(total_wns, s['WNS'])
                total_tns += s['TNS']
                total_num += s['NUM']
                total_lt  += s.get('LessThan', 0)
    return total_wns, total_tns, total_num, total_lt


