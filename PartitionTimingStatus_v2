def _get_ps(pattern: str) -> List[str]:
    """Return list of running process command lines matching pattern (Linux /proc)."""
    matches = []
    for pid in filter(str.isdigit, os.listdir('/proc')):
        try:
            with open(f'/proc/{pid}/cmdline', 'r') as f:
                cmd = f.read().replace('\0', ' ')
                if pattern in cmd:
                    matches.append(f"{pid} {cmd}")
        except OSError:
            continue
    return matches


def check_libreoffice_conflict():
    """Exit with error if another LibreOffice process is already running."""
    if _get_ps('libreoffice'):
        print(f"{COLOR_R}Error: Another LibreOffice process is running. "
              f"Please close it before running this script.{NO_COLOR}")
        sys.exit(1)


def read_xlsx(filename: str, sheet_name=0) -> pd.DataFrame:
    file_path = os.path.abspath(filename)
    print(f"Reading {file_path} ...")
    return pd.read_excel(file_path, sheet_name=sheet_name, engine='openpyxl')


def read_ods(filename: str, sheet_name=0) -> pd.DataFrame:
    """Convert ODS to XLSX via soffice, read with openpyxl, return DataFrame."""
    file_path = os.path.abspath(filename)
    with tempfile.TemporaryDirectory() as tmp_dir:
        cmd = ['soffice', '--headless', '--convert-to', 'xlsx', '--outdir', tmp_dir, file_path]
        subprocess.run(cmd, check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        base      = os.path.splitext(os.path.basename(file_path))[0]
        converted = os.path.join(tmp_dir, f"{base}.xlsx")
        print(f"Reading {file_path} ... (converted via soffice)")
        return pd.read_excel(converted, sheet_name=sheet_name, engine='openpyxl')


def read_xlsx_ods(filename: str, sheet_name=0) -> pd.DataFrame:
    ext = os.path.splitext(filename)[1].lower()
    if ext == '.xlsx':
        return read_xlsx(filename, sheet_name=sheet_name)
    elif ext == '.ods':
        return read_ods(filename, sheet_name=sheet_name)
    else:
        raise ValueError(f"Unsupported file extension: {ext}")


def _freeze_cell_to_col_row(freeze: str) -> tuple:
    """
    Convert openpyxl freeze_panes string (e.g. 'E2') to
    0-based (col_index, row_index) for ODS settings.xml.
    Returns (0, 0) if freeze is None/empty.
    """
    if not freeze:
        return 0, 0
    m = re.match(r'^([A-Z]+)(\d+)$', freeze.strip().upper())
    if not m:
        return 0, 0
    col_str, row_str = m.group(1), m.group(2)
    col = 0
    for ch in col_str:
        col = col * 26 + (ord(ch) - ord('A') + 1)
    return col - 1, int(row_str) - 1  # 0-based


def _build_views_xml(sheet_name: str, col: int, row: int) -> str:
    """
    Build the config:config-item-map-indexed block for the Views entry
    that encodes freeze panes. This is injected *inside* the existing
    ooo:view-settings config-item-set in settings.xml.

    col, row are 0-based (e.g. E2 → col=5, row=1).
    HorizontalSplitMode / VerticalSplitMode = 2 means freeze.
    """
    return (
        '<config:config-item-map-indexed config:name="Views">'
        '<config:config-item-map-entry>'
        '<config:config-item config:name="ViewId" config:type="string">view1</config:config-item>'
        '<config:config-item-map-named config:name="Tables">'
        f'<config:config-item-map-entry config:name="{sheet_name}">'
        f'<config:config-item config:name="HorizontalSplitMode" config:type="short">{2 if col else 0}</config:config-item>'
        f'<config:config-item config:name="VerticalSplitMode" config:type="short">{2 if row else 0}</config:config-item>'
        f'<config:config-item config:name="HorizontalSplitPosition" config:type="int">{col}</config:config-item>'
        f'<config:config-item config:name="VerticalSplitPosition" config:type="int">{row}</config:config-item>'
        f'<config:config-item config:name="PositionLeft" config:type="int">0</config:config-item>'
        f'<config:config-item config:name="PositionRight" config:type="int">{col}</config:config-item>'
        f'<config:config-item config:name="PositionTop" config:type="int">0</config:config-item>'
        f'<config:config-item config:name="PositionBottom" config:type="int">{row}</config:config-item>'
        '<config:config-item config:name="ZoomType" config:type="short">0</config:config-item>'
        '<config:config-item config:name="ZoomValue" config:type="int">100</config:config-item>'
        '<config:config-item config:name="ActiveSplitRange" config:type="short">3</config:config-item>'
        '</config:config-item-map-entry>'
        '</config:config-item-map-named>'
        '</config:config-item-map-entry>'
        '</config:config-item-map-indexed>'
    )


def _patch_ods_shared_mode(ods_path: str, freeze: str = 'E2',
                           sheet_name: str = 'Overall'):
    try:
        col, row = _freeze_cell_to_col_row(freeze)

        # ── 1. Read and patch settings.xml in memory ──────────────
        with zipfile.ZipFile(ods_path, 'r') as zr:
            try:
                content = zr.read('settings.xml').decode('utf-8')
            except KeyError:
                logging.warning(f"settings.xml not found in {ods_path}, skipping patch")
                return

        # Patch IsDocumentShared
        patched = re.sub(
            r'(<config:config-item\s+config:name="IsDocumentShared"'
            r'\s+config:type="boolean">)false(</config:config-item>)',
            r'\1true\2',
            content)

        # Inject Views/freeze block
        VIEW_SET_MARKER = 'config:name="ooo:view-settings"'
        CLOSE_TAG       = '</config:config-item-set>'
        if (col or row) and VIEW_SET_MARKER in patched \
                and 'config:name="Views"' not in patched:
            views_xml = _build_views_xml(sheet_name, col, row)
            insert_at = patched.index(CLOSE_TAG, patched.index(VIEW_SET_MARKER))
            patched   = patched[:insert_at] + views_xml + patched[insert_at:]

        # ── 2. Write patched settings.xml back using append mode ───
        # zipfile append mode adds a new entry with the same name;
        # the last entry wins when the file is read, so no full repack needed.
        with zipfile.ZipFile(ods_path, 'a') as zw:
            zw.writestr('settings.xml', patched.encode('utf-8'))

    except Exception as e:
        print(f"{COLOR_R}Error: Failed to patch ODS: {e}{NO_COLOR}")


def convert_to_ods_shared(xlsx_path: str, freeze: str = 'E2',
                          sheet_name: str = 'Overall') -> str:
    """
    Convert xlsx → ods via soffice, patch shared edit mode + freeze panes,
    remove xlsx.  Returns the resulting .ods file path.
    """
    cmd = ['soffice', '--headless', '--convert-to', 'ods', xlsx_path]
    subprocess.run(cmd, check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    os.remove(xlsx_path)
    ods_path = os.path.splitext(xlsx_path)[0] + '.ods'
    _patch_ods_shared_mode(ods_path, freeze=freeze, sheet_name=sheet_name)
    print(f"Output converted to ODS (shared mode + freeze enabled): {ods_path}")
    return ods_path


