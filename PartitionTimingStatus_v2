_EACH_SCENARIO_SUFFIX = "_each_scenario"
_SHEET_NAME_MAX       = 31


def _partition_sheet_names(partition_name: str) -> tuple:
    """Return (agg_sheet_name, scenario_sheet_name) within Excel's 31-char limit."""
    agg  = partition_name[:_SHEET_NAME_MAX]
    scen = partition_name[:_SHEET_NAME_MAX - len(_EACH_SCENARIO_SUFFIX)] + _EACH_SCENARIO_SUFFIX
    return agg, scen


def _write_partition_sheets(writer, partition_name: str,
                             sections: dict, scenario_mode: str):
    """
    Write per-partition PBA detail sheets into an already-open ExcelWriter.

    Sheet 1  {partition_name}               : violation_type × clock_group → WNS/TNS/NVP
    Sheet 2  {partition_name}_each_scenario : violation_type × clock_group × scenario (DMSA only)
    """
    if not sections:
        return

    agg_name, scen_name = _partition_sheet_names(partition_name)

    # ── Sheet 1: aggregated across scenarios ──────────────────
    rows_agg = []
    for vtype, clock_groups in sections.items():
        for group_name, scenarios in clock_groups.items():
            wns, tns, num = 0, 0.0, 0
            for s in scenarios.values():
                wns  = min(wns, s['WNS'])
                tns += s['TNS']
                num += s['NUM']
            rows_agg.append({
                'ViolationType': vtype,
                'ClockGroup':    group_name,
                'WNS':           wns,
                'TNS':           round(tns, 4),
                'NVP':           num,
            })
    if rows_agg:
        pd.DataFrame(rows_agg).to_excel(writer, sheet_name=agg_name, index=False)
        ws = writer.book[agg_name]
        _apply_header_style(ws)
        _auto_col_width(ws)

    # ── Sheet 2: per-scenario (DMSA only) ─────────────────────
    if scenario_mode != 'DMSA':
        return
    rows_scen = []
    for vtype, clock_groups in sections.items():
        for group_name, scenarios in clock_groups.items():
            for scenario, s in scenarios.items():
                rows_scen.append({
                    'ViolationType': vtype,
                    'ClockGroup':    group_name,
                    'Scenario':      scenario,
                    'WNS':           s['WNS'],
                    'TNS':           round(s['TNS'], 4),
                    'NVP':           s['NUM'],
                })
    if rows_scen:
        pd.DataFrame(rows_scen).to_excel(writer, sheet_name=scen_name, index=False)
        ws = writer.book[scen_name]
        _apply_header_style(ws)
        _auto_col_width(ws)


