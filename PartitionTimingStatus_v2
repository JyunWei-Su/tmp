def _timing_diff_font_color(raw) -> Optional[str]:
    """
    Determine font color for a Setup(*) / Hold(*) _diff cell.
    Cell value is a scalar (NVP-only diff) or 'WNS_diff / TNS_diff / NVP_diff'.

    Per-token improvement direction:
      index 0 (WNS) : > 0 is good (improved)
      index 1 (TNS) : > 0 is good (improved)
      index 2 (NVP) : < 0 is good (fewer violations)

    Overall cell color (most conservative):
      - Any token violates its rule → red  "FF0000"
      - All tokens improved         → green "00AA00"
      - All tokens = 0              → black (None)
      - NA / err / non-numeric      → black (None)
    """
    if raw is None:
        return None
    if isinstance(raw, (int, float)):
        # scalar: treat as WNS-style (positive = improved)
        v = float(raw)
        if v < 0:
            return "FF0000"
        if v > 0:
            return "00AA00"
        return None

    parts = [p.strip() for p in str(raw).split('/')]
    try:
        tokens = [float(p) for p in parts]
    except ValueError:
        return None  # non-numeric (NA, err) → black

    # Map token index → True if "positive direction is good"
    # index 0=WNS, 1=TNS: higher is better; index 2=NVP: lower is better
    def _is_bad(idx: int, val: float) -> bool:
        if idx == 2:          # NVP: violation when > 0
            return val > 0
        else:                 # WNS/TNS: violation when < 0
            return val < 0

    def _is_good(idx: int, val: float) -> bool:
        if idx == 2:
            return val < 0
        else:
            return val > 0

    if any(_is_bad(i, t) for i, t in enumerate(tokens)):
        return "FF0000"
    if all(_is_good(i, t) for i, t in enumerate(tokens)):
        return "00AA00"
    return None  # all zero or mixed zero/good → black


def _count_diff_font_color(raw) -> Optional[str]:
    """
    Determine font color for violation-count _diff cells
    (MaxTransVio, MaxCapVio, MinPulseWidth, MinPeriod).
    Lower count = improved → green; higher count = worse → red.

    Value may be scalar or 'a / b' slash-separated (e.g. MaxTransVio lt/total).
    Any token > 0 → red; all tokens < 0 → green; all zero → black.
    """
    if raw is None:
        return None
    if isinstance(raw, (int, float)):
        v = float(raw)
        if v > 0:  return "FF0000"
        if v < 0:  return "00AA00"
        return None
    parts = [p.strip() for p in str(raw).split('/')]
    try:
        tokens = [float(p) for p in parts]
    except ValueError:
        return None
    if any(t > 0 for t in tokens):  return "FF0000"
    if all(t < 0 for t in tokens):  return "00AA00"
    return None


def _apply_timing_diff_colors(ws, df_out: pd.DataFrame):
    """
    Apply red/green/black font to timing _diff columns.
    - Setup(*) / Hold(*): WNS/TNS higher=good, NVP lower=good
    - MaxTransVio(*) / MaxCapVio / MinPulseWidth / MinPeriod: count lower=good
    Must run after _apply_row_colors so fill is already set.
    """
    _COUNT_PREFIXES = ('MaxTransVio(', 'MaxCapVio', 'MinPulseWidth', 'MinPeriod')
    timing_diff_cols = {
        str(col): (idx + 1,
                   _count_diff_font_color if str(col).startswith(_COUNT_PREFIXES)
                   else _timing_diff_font_color)
        for idx, col in enumerate(df_out.columns)
        if isinstance(col, str) and '_diff' in col and
           (col.startswith('Setup(') or col.startswith('Hold(')
            or col.startswith(_COUNT_PREFIXES))
    }
    for _, (col_idx, color_fn) in timing_diff_cols.items():
        for row_idx in range(2, ws.max_row + 1):
            cell  = ws.cell(row=row_idx, column=col_idx)
            color = color_fn(cell.value)
            if color:
                cell.font = Font(color=color)
                cell.alignment = Alignment(
                    horizontal=cell.alignment.horizontal or 'left',
                    vertical='center',
                    wrap_text=cell.alignment.wrap_text,
                )


