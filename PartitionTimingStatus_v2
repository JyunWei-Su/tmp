def mode_diff(file_old: str, file_new: str, output_ods: bool):
    """
    Diff mode: load two Partition_Timing_Status files, compute column-wise
    differences, and write Partition_Timing_Status_<date_new>_Diff.xlsx/ods.
    """
    date_old = get_date_from_filename(file_old)
    date_new = get_date_from_filename(file_new)

    df_old = read_xlsx_ods(file_old, sheet_name='Overall')
    df_new = read_xlsx_ods(file_new, sheet_name='Overall')

    # Drop only _diff columns — they will be recomputed.
    # _v{mmdd} versioned columns are intentionally kept: when --old/--new is itself
    # a previously diff-ed file, those versioned columns ARE the data we need.
    # tag_columns_with_date already skips columns that are already versioned.
    _stale_diff = re.compile(r'_diff$', re.IGNORECASE)
    for _df in (df_old, df_new):
        _drop = [c for c in _df.columns if isinstance(c, str) and _stale_diff.search(c)]
        if _drop:
            _df.drop(columns=_drop, inplace=True)

    # Normalise legacy column names so old and new files can be mixed freely
    df_old = _normalize_legacy_columns(df_old)
    df_new = _normalize_legacy_columns(df_new)

    partitions = df_new[COL_PARTITION].dropna().tolist()

    # Columns that carry metadata — do NOT get date-versioned
    exclude_from_date = [COL_PARTITION, COL_BEOWNER, COL_APR_STAGE, COL_SI_NSI]

    df_old_v = tag_columns_with_date(df_old, date_old, exclude=exclude_from_date)
    df_new_v = tag_columns_with_date(df_new, date_new, exclude=exclude_from_date)

    # Patterns to pull from each versioned frame
    keep_patterns = [
        'Comment*', f'{COL_SI_PARAMS_ERRORS}*',
        'Setup*', 'Hold*',
        'MaxTransVio*', f'{COL_MAX_CAP_VIO}*',
        f'{COL_MIN_PULSE_WIDTH}*', f'{COL_MIN_PERIOD}*',
        f'{COL_NOISE}*', f'{COL_DOUBLE_SWITCHING}*',
    ]
    df_old_v = select_columns(df_old_v, include=keep_patterns, exclude=['*_diff*', '*_diff'])
    df_new_v = select_columns(df_new_v, include=keep_patterns, exclude=['*_diff*', '*_diff'])

    df_head     = lookup_partitions(df_new, partitions,
                                    cols=[COL_BEOWNER, COL_APR_STAGE, COL_SI_NSI])
    df_from_old = lookup_partitions(df_old_v, partitions)
    df_from_new = lookup_partitions(df_new_v, partitions)

    # Base column names for diff computation
    base_diff_cols = [
        COL_SI_PARAMS_ERRORS,
        col_setup("Total"), col_setup("REG2REG"), col_setup("IN2REG"),
        col_setup("REG2OUT"), col_setup("IN2OUT"),
        col_hold("Total"),  col_hold("REG2REG"),  col_hold("IN2REG"),
        col_hold("REG2OUT"), col_hold("IN2OUT"),
        COL_MAX_CAP_VIO, COL_MIN_PULSE_WIDTH, COL_MIN_PERIOD,
        COL_NOISE, COL_DOUBLE_SWITCHING,
    ]
    # MaxTransVio column name is dynamic (depends on threshold used at extract time)
    # Discover it from the new file's columns by pattern
    max_trans_bases = list({
        re.sub(r'_v\d{4}$', '', c)
        for c in df_from_new.columns
        if 'MaxTransVio' in c
    })
    diff_cols = list(dict.fromkeys(base_diff_cols + max_trans_bases))

    sort_list = [
        COL_PARTITION, COL_BEOWNER, COL_APR_STAGE, COL_SI_NSI, COL_COMMENT
    ] + diff_cols

    df_merged = merge_dataframes([df_head, df_from_old, df_from_new])
    df_diff   = compute_diff(df_merged, date_new=date_new, date_old=date_old,
                             cols=diff_cols)
    df_diff   = merge_dataframes([df_diff], sort_list=sort_list,
                                 date_new=date_new, date_old=date_old)

    # Any columns that are neither metadata, diff, nor versioned data → hide
    meta_subs = [COL_PARTITION, 'BEOwner', 'APRStage', 'SI/nSI', 'Comment']
    extra_hide = [
        c for c in df_diff.columns
        if not any(sub in str(c) for sub in
                   meta_subs + ['_diff', date_new[4:], date_old[4:]])
    ]

    out_xlsx = f"Partition_Timing_Status_{date_new}_Diff.xlsx"
    with pd.ExcelWriter(out_xlsx, engine='openpyxl') as writer:
        _write_sheet(writer, df_diff,
                     sheet_name    = 'Overall',
                     freeze        = 'E2',
                     color_rules   = DIFF_COLOR_RULES,
                     hide_patterns = DIFF_HIDE_DEFAULT + extra_hide)

    # Remove stale diff symlinks
    for ext in ('xlsx', 'ods'):
        link = f"Partition_Timing_Status_diff.{ext}"
        if os.path.exists(link) or os.path.islink(link):
            os.remove(link)

    if output_ods:
        ods_path = convert_to_ods_shared(out_xlsx, freeze='E2', sheet_name='Overall')
        os.symlink(ods_path, "Partition_Timing_Status_diff.ods")
    else:
        print(f"Diff output written to: {out_xlsx}")
        os.symlink(out_xlsx, "Partition_Timing_Status_diff.xlsx")


