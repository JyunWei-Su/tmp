# 刪除（dry-run 預設）

# ============================================================

def do_delete(entries: list[FileEntry], dry_run: bool):
import shutil

```
deletable = [e for e in entries if e.level in (LOW, MEDIUM)]
if not deletable:
    print("沒有可刪除的項目（High Risk / DON'T TOUCH 不自動刪除）。")
    return

print(f"\n{'[DRY-RUN] 模擬刪除' if dry_run else '⚠️  真正刪除'} {len(deletable)} 項：\n")
for e in deletable:
    tag = "[DRY-RUN]" if dry_run else "[DELETE] "
    print(f"  {tag} {e.path}")
    if not dry_run:
        try:
            if e.path.is_dir():
                shutil.rmtree(e.path)
            else:
                e.path.unlink()
        except Exception as ex:
            print(f"           ❌ 失敗: {ex}")

if dry_run:
    print("\n（加上 --delete 才會真正執行刪除）")
```

