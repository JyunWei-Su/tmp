def build_parser() -> argparse.ArgumentParser:
p = argparse.ArgumentParser(
description=“IC Design 專案檔案清理分類工具”,
formatter_class=argparse.RawDescriptionHelpFormatter,
epilog=**doc**,
)
p.add_argument(“root”, help=“掃描根目錄”)
p.add_argument(
“–output”, metavar=“FILE”, default=None,
help=“將結果同時寫入檔案”
)
p.add_argument(
“–delete”, action=“store_true”, default=False,
help=“真正執行刪除（預設為 dry-run，僅列出）”
)
p.add_argument(
“–level”, metavar=“LEVEL”, default=None,
choices=[“low”, “medium”, “high”, “dont_touch”],
help=“只顯示指定等級（low / medium / high / dont_touch）”
)
p.add_argument(
“–sort”, metavar=“BY”, default=“LEVEL”,
choices=[“SIZE”, “TIME”, “LEVEL”, “PATH”],
help=“排序方式：SIZE / TIME / LEVEL / PATH（預設 LEVEL）”
)
return p

LEVEL_MAP = {
“low”:        LOW,
“medium”:     MEDIUM,
“high”:       HIGH,
“dont_touch”: DONT,
}

def main():
parser = build_parser()
args = parser.parse_args()

