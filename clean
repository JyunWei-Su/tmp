# 掃描

# ============================================================

@dataclass
class FileEntry:
path: Path
size: int           # bytes
mtime: float        # unix timestamp
level: str
desc: str

```
@property
def size_hr(self) -> str:
    """human-readable size"""
    for unit in ("B", "KB", "MB", "GB", "TB"):
        if self.size < 1024:
            return f"{self.size:.1f} {unit}"
        self.size /= 1024
    return f"{self.size:.1f} PB"

@property
def mtime_str(self) -> str:
    return datetime.fromtimestamp(self.mtime).strftime("%Y-%m-%d %H:%M")
```

def scan(root: Path) -> list[FileEntry]:
entries: list[FileEntry] = []
for dirpath, dirnames, filenames in os.walk(root):
dp = Path(dirpath)

```
    # 先對目錄名比對（可捕捉 *xcelium.d 之類的目錄）
    for dname in list(dirnames):
        result = classify(dname)
        if result:
            level, desc = result
            full = dp / dname
            try:
                stat = full.stat()
                size = sum(
                    f.stat().st_size
                    for f in full.rglob("*")
                    if f.is_file()
                )
                entries.append(FileEntry(full, size, stat.st_mtime, level, desc))
            except PermissionError:
                pass
            # 若目錄已命中，不再往下掃其內部（避免重複列出子項）
            dirnames.remove(dname)

    # 對檔案比對
    for fname in filenames:
        result = classify(fname)
        if result:
            level, desc = result
            full = dp / fname
            try:
                stat = full.stat()
                entries.append(FileEntry(full, stat.st_size, stat.st_mtime, level, desc))
            except PermissionError:
                pass

return entries
