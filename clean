# 輸出

# ============================================================

COL_WIDTHS = {
“size”:  10,
“time”:  16,
“level”: 14,
}

def fmt_row(entry: FileEntry, root: Path) -> str:
rel = entry.path.relative_to(root)
symbol = LEVEL_SYMBOL[entry.level]
level_col = f”{symbol} {entry.level}”
# 計算 size（可能已被 size_hr 消耗，重新抓）
stat_size = entry.path.stat().st_size if entry.path.is_file() else entry.size
size_str = FileEntry(entry.path, stat_size, entry.mtime, entry.level, entry.desc).size_hr
return (
f”{size_str:>{COL_WIDTHS[‘size’]}}  “
f”{entry.mtime_str:<{COL_WIDTHS[‘time’]}}  “
f”{level_col:<{COL_WIDTHS[‘level’]+3}}  “
f”{rel}”
)

HEADER = (
f”{‘SIZE’:>{COL_WIDTHS[‘size’]}}  “
f”{‘MODIFIED’:<{COL_WIDTHS[‘time’]}}  “
f”{‘RISK LEVEL’:<{COL_WIDTHS[‘level’]+3}}  “
f”PATH”
)
SEPARATOR = “-” * 100

def print_report(entries: list[FileEntry], root: Path, output_file: str | None):
lines = [HEADER, SEPARATOR]
for e in entries:
try:
lines.append(fmt_row(e, root))
except Exception:
lines.append(f”{’(error)’:>{COL_WIDTHS[‘size’]}}  {’’:16}  {e.level:<17}  {e.path}”)

