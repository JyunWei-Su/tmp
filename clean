def classify(name: str) -> tuple[str, str] | None:
“””
對單一檔名（或目錄名）套用規則，回傳 (risk_level, description)。
規則按順序比對，第一個命中的優先（先寫先贏）。
“””
for pattern, level, desc in RULES:
if fnmatch.fnmatch(name, pattern):
return level, desc
return None

