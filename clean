# 排序

# ============================================================

SORT_KEYS = {
“SIZE”:  lambda e: e.size,
“TIME”:  lambda e: e.mtime,
“LEVEL”: lambda e: LEVEL_ORDER[e.level],
“PATH”:  lambda e: str(e.path),
}

def sort_entries(entries: list[FileEntry], by: str) -> list[FileEntry]:
key = SORT_KEYS.get(by.upper(), SORT_KEYS[“LEVEL”])
return sorted(entries, key=key)

